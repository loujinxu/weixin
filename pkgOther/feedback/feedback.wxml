<!--pages/feedback/feedback.wxml-->
<view class="container">
  <view class="tips-card">
    <text class="tips-text">请选择反馈类型并描述问题，我们会尽快处理。</text>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="form-label">反馈类型</text>
      <picker mode="selector" range="{{typeList}}" range-key="name" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">
          <text>{{typeList[typeIndex].name}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">问题描述</text>
      <textarea
        class="textarea"
        placeholder="请详细描述您遇到的问题（如座位号、区域、具体现象等）"
        placeholder-class="placeholder"
        value="{{content}}"
        maxlength="500"
        show-confirm-bar="{{false}}"
        bindinput="onContentInput"
      />
      <text class="char-count">{{content.length}}/500</text>
    </view>

    <view class="form-item" wx:if="{{typeIndex === 0}}">
      <text class="form-label">座位/设施位置（选填）</text>
      <input
        class="input"
        placeholder="如：A区3排5号座位"
        value="{{location}}"
        bindinput="onLocationInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">上传图片（选填，最多9张）</text>
      <view class="image-upload-wrap">
        <view class="image-list">
          <view class="image-item" wx:for="{{images}}" wx:key="*this">
            <image class="thumb" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
            <view class="thumb-del" bindtap="removeImage" data-index="{{index}}">×</view>
          </view>
          <view class="image-add" wx:if="{{images.length < 9}}" bindtap="chooseImage">
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-submit" bindtap="submit">提交反馈</button>
  </view>
</view>
