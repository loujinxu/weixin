.reservation-container{min-height:100vh;background:#f5f5f5;padding:20rpx;display:flex;flex-direction:column;align-items:center}
.card{background:#fff;border-radius:20rpx;padding:40rpx 30rpx;margin-bottom:30rpx;box-shadow:0 4rpx 20rpx rgba(0,0,0,.08);width:100%;box-sizing:border-box}
.seat-info-card{display:flex;flex-direction:column;align-items:center;border-left:8rpx solid #4a90e2}
.card-title{font-size:32rpx;color:#333;font-weight:600;margin-bottom:20rpx;text-align:center}
.seat-number{font-size:48rpx;color:#4a90e2;font-weight:bold;margin-bottom:10rpx;text-align:center}
.reservation-hours{font-size:28rpx;color:#666;text-align:center}
.countdown-card{display:flex;flex-direction:column;align-items:center;background:linear-gradient(135deg,#4a90e2,#2e6fba);border-left:8rpx solid #1e5fa0}
.countdown-label{font-size:28rpx;color:rgba(255,255,255,.9);margin-bottom:20rpx}
.countdown-text{font-size:72rpx;color:#fff;font-weight:bold;font-family:'Courier New',Consolas,monospace}
.temp-info-card{border-left:8rpx solid #f5a623;display:flex;flex-direction:column;align-items:center}
.temp-leave-count{font-size:36rpx;color:#f5a623;font-weight:bold;margin-bottom:10rpx}
.temp-leave-description{font-size:24rpx;color:#666}
.action-buttons{width:100%;display:flex;flex-direction:column;gap:20rpx;margin-top:20rpx}
.btn{width:100%;height:100rpx;border-radius:50rpx;font-size:32rpx;font-weight:500;display:flex;align-items:center;justify-content:center;border:none;margin:0}
.btn::after{border:none}
.temp-leave-btn{background:linear-gradient(135deg,#f5a623,#e68a00);color:#fff}
.temp-leave-btn[disabled]{background:#ccc;color:#999}
.end-reservation-btn{background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff}
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);display:flex;justify-content:center;align-items:center;z-index:1000}
.modal-container{width:80vw;max-width:600rpx;background:#fff;border-radius:20rpx;overflow:hidden;box-shadow:0 10rpx 30rpx rgba(0,0,0,.2)}
.modal-header{padding:40rpx 30rpx 20rpx;background:#4a90e2;text-align:center}
.modal-title{font-size:36rpx;color:#fff;font-weight:600}
.modal-content{padding:40rpx 30rpx;text-align:center}
.modal-message{font-size:32rpx;color:#333;margin-bottom:20rpx}
.modal-subtitle{font-size:28rpx;color:#666}
.modal-actions{padding:0 30rpx 30rpx;display:flex;flex-direction:column;gap:20rpx}
.modal-button{height:80rpx;border-radius:40rpx;font-size:32rpx;font-weight:500;border:none;display:flex;align-items:center;justify-content:center}
.renew-button{background:linear-gradient(135deg,#27ae60,#219653);color:#fff}
.confirm-button{background:#f8f9fa;color:#666;border:2rpx solid #e0e0e0}
