/* pkgFlow/timeSelect/timeSelect.wxss */
.container{min-height:100vh;background:#f5f7fa;font-family:-apple-system,BlinkMacSystemFont,'Microsoft YaHei',sans-serif}
.header{display:flex;align-items:center;height:100rpx;padding:0 30rpx;background:linear-gradient(135deg,#2c3e50,#4a6491);color:#fff;position:sticky;top:0;z-index:100}
.back-btn{font-size:50rpx;font-weight:bold;width:60rpx;height:60rpx;line-height:50rpx;text-align:center;margin-right:20rpx}
.header-title{font-size:36rpx;font-weight:bold;flex:1;text-align:center;margin-right:60rpx}
.seat-info{padding:30rpx 40rpx;background:#fff;border-bottom:1rpx solid #f0f0f0}
.info-content{display:flex;flex-direction:column;align-items:center;gap:15rpx;background:#f8f9fa;padding:25rpx;border-radius:12rpx;border:2rpx solid #e0e0e0}
.info-label{font-size:30rpx;color:#333;font-weight:500}
.seat-number{font-size:40rpx;color:#3498db;font-weight:bold}
.time-section{padding:40rpx 30rpx;background:#fff;min-height:600rpx}
.section-title{font-size:34rpx;color:#333;font-weight:600;text-align:center;margin-bottom:40rpx}
.time-slots{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx;margin-bottom:40rpx}
.time-slot{background:#f8f9fa;border:2rpx solid #e0e0e0;border-radius:12rpx;padding:30rpx 20rpx;display:flex;flex-direction:column;align-items:center;gap:10rpx}
.time-slot.active{background:linear-gradient(135deg,#3498db,#2980b9);border-color:#2980b9;color:#fff}
.time-text{font-size:36rpx;font-weight:bold;color:#333}
.time-subtext{font-size:24rpx;color:#666}
.selected-info{background:linear-gradient(135deg,#f0f9ff,#e8f4ff);border-radius:12rpx;padding:25rpx 30rpx;border:2rpx solid #3498db;margin-top:20rpx;text-align:center}
.selected-text{font-size:30rpx;color:#2c3e50;font-weight:bold}
.temp-info{font-size:26rpx;color:#27ae60}
.action-buttons{position:fixed;bottom:0;left:0;right:0;display:flex;padding:20rpx 30rpx;background:#fff;border-top:1rpx solid #f0f0f0;gap:20rpx}
.btn{flex:1;height:100rpx;border-radius:12rpx;font-size:32rpx;font-weight:500;border:none}
.btn::after{border:none}
.btn.cancel{background:#f5f5f5;color:#666}
.btn.confirm{background:linear-gradient(135deg,#3498db,#2980b9);color:#fff}
.btn.confirm[disabled]{background:#ccc;color:#999}
