.container{min-height:100vh;background:#fff;font-family:-apple-system,BlinkMacSystemFont,'Microsoft YaHei',sans-serif;padding:0;margin:0}
.header{height:100rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#e67e22,#d35400);color:#fff;box-shadow:0 2rpx 8rpx rgba(0,0,0,.1)}
.header-title{font-size:36rpx;font-weight:bold}
.seat-info{padding:30rpx 40rpx;background:linear-gradient(135deg,#fef9e7,#fdebd0);border-bottom:2rpx solid #e67e22}
.info-content{display:flex;flex-direction:column;align-items:center;gap:20rpx;background:#fff;padding:25rpx;border-radius:20rpx;border:2rpx solid #e67e22;text-align:center}
.info-label{font-size:30rpx;color:#2c3e50;font-weight:600}
.seat-display{display:flex;align-items:center;gap:20rpx;justify-content:center;flex-wrap:wrap}
.seat-number-big{font-size:50rpx;color:#e67e22;font-weight:bold}
.temp-status{font-size:32rpx;color:#e67e22;background:#fef5e7;padding:8rpx 20rpx;border-radius:20rpx;border:2rpx solid #e67e22;font-weight:700}
.countdown-section{padding:40rpx 30rpx;background:#fef9e7;border-bottom:1rpx solid #fdebd0}
.countdown-title{font-size:32rpx;color:#e67e22;font-weight:600;text-align:center;margin-bottom:30rpx}
.countdown-display{background:linear-gradient(135deg,#e67e22,#d35400);border-radius:20rpx;padding:50rpx 30rpx;text-align:center;box-shadow:0 8rpx 20rpx rgba(230,126,34,.3);margin-bottom:30rpx}
.countdown-text{font-size:72rpx;color:#fff;font-weight:bold;font-family:'Courier New',monospace;letter-spacing:4rpx}
.tip-text{font-size:28rpx;color:#e67e22;text-align:center;font-weight:500;background:#fff;padding:20rpx 30rpx;border-radius:12rpx;border:2rpx solid #fdebd0}
.action-section{padding:40rpx 30rpx}
.action-btn{width:100%;height:120rpx;border-radius:16rpx;font-size:36rpx;font-weight:600;background:linear-gradient(135deg,#3498db,#2980b9);color:#fff;border:none;display:flex;align-items:center;justify-content:center}
.action-btn::after{border:none}
