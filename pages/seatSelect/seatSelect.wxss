/* pages/seatSelect/seatSelect.wxss */
.container { min-height: 100vh; background-color: #f8f9fa; font-family: -apple-system, BlinkMacSystemFont, 'Microsoft YaHei', sans-serif; }
.floor-tab-bar { display: flex; justify-content: space-around; background-color: #fff; padding: 20rpx 0; border-bottom: 1rpx solid #e0e0e0; position: sticky; top: 0; z-index: 10; }
.floor-tab { width: 120rpx; height: 80rpx; line-height: 80rpx; text-align: center; font-size: 32rpx; font-weight: 500; border-radius: 40rpx; background-color: #f5f7fa; color: #666; }
.floor-tab.active { background: linear-gradient(135deg, #3498db, #2980b9); color: #fff; box-shadow: 0 4rpx 8rpx rgba(52,152,219,0.2); }
.seat-scroll { height: calc(100vh - 120rpx); padding: 20rpx; box-sizing: border-box; }
.seat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; justify-items: center; }
.seat-card { width: 100rpx; height: 100rpx; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); position: relative; }
.seat-number { font-size: 28rpx; font-weight: 700; text-align: center; line-height: 1; color: #fff; }
.seat-status { position: absolute; bottom: 4rpx; right: 4rpx; font-size: 16rpx; color: #fff; font-weight: 500; transform: scale(0.8); transform-origin: bottom right; white-space: nowrap; }
