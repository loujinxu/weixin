/* pages/timeslot/timeslot.wxss */
.slot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.slot-item {
  width: calc(33.33% - 16rpx);
  padding: 32rpx 0;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
}
.slot-item.selected {
  background: #1a5fb4;
  color: #fff;
}
.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}
.btn-secondary {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: #e0e0e0;
  color: #333;
  border-radius: 12rpx;
  font-size: 32rpx;
}
.btn-primary {
  flex: 1;
}
