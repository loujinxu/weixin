/* pages/timeSelect/timeSelect.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Microsoft YaHei', sans-serif;
}

.header {
  display: flex;
  align-items: center;
  height: 100rpx;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #2c3e50, #4a6491);
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.back-btn {
  font-size: 50rpx;
  font-weight: bold;
  width: 60rpx;
  height: 60rpx;
  line-height: 50rpx;
  text-align: center;
  margin-right: 20rpx;
  cursor: pointer;
  opacity: 0.9;
  transition: all 0.2s;
}

.back-btn:active {
  opacity: 0.7;
  transform: scale(0.9);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  text-align: center;
  margin-right: 60rpx;
  letter-spacing: 1.5rpx;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.2);
}

.seat-info {
  padding: 30rpx 40rpx;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  animation: fadeInUp 0.5s ease-out 0.1s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.info-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  background-color: #f8f9fa;
  padding: 25rpx 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.info-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.seat-number {
  font-size: 40rpx;
  color: #3498db;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(52,152,219,0.2);
}

.process-indicator {
  font-size: 24rpx;
  color: #e67e22;
  background-color: #fef5e7;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e67e22;
}

.reservation-count {
  font-size: 24rpx;
  color: #27ae60;
  background-color: #e8f8f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #27ae60;
}

.time-section {
  padding: 40rpx 30rpx;
  background-color: white;
  min-height: 600rpx;
  animation: fadeInUp 0.5s ease-out 0.2s both;
}

.section-title {
  font-size: 34rpx;
  color: #333333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  padding-bottom: 20rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #3498db, #2980b9);
  border-radius: 2rpx;
}

.time-slots {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.time-slot {
  background-color: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.05);
  animation: slotAppear 0.5s ease-out;
  animation-fill-mode: both;
}

.time-slot:nth-child(1) { animation-delay: 0.1s; }
.time-slot:nth-child(2) { animation-delay: 0.2s; }
.time-slot:nth-child(3) { animation-delay: 0.3s; }
.time-slot:nth-child(4) { animation-delay: 0.4s; }
.time-slot:nth-child(5) { animation-delay: 0.5s; }
.time-slot:nth-child(6) { animation-delay: 0.6s; }

@keyframes slotAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.time-slot:active {
  transform: scale(0.98);
}

.time-slot.active {
  background: linear-gradient(135deg, #3498db, #2980b9);
  border-color: #2980b9;
  box-shadow: 0 6rpx 12rpx rgba(52,152,219,0.2);
}

.time-slot.active .time-text,
.time-slot.active .time-subtext {
  color: white;
}

.time-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.time-subtext {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
  text-align: center;
}

.selected-info {
  background: linear-gradient(135deg, #f0f9ff, #e8f4ff);
  border-radius: 12rpx;
  padding: 25rpx 30rpx;
  border: 2rpx solid #3498db;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  animation: fadeIn 0.3s ease-out;
  text-align: center;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.selected-text {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: bold;
}

.temp-info {
  font-size: 26rpx;
  color: #27ae60;
  font-weight: 500;
}

.renew-notice {
  font-size: 24rpx;
  color: #e67e22;
  background-color: #fef5e7;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e67e22;
  line-height: 1.4;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: white;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn.cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.btn.cancel:active {
  background-color: #e0e0e0;
  transform: scale(0.98);
}

.btn.confirm {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
  box-shadow: 0 4rpx 8rpx rgba(52,152,219,0.2);
}

.btn.confirm[disabled] {
  background-color: #cccccc;
  color: #999999;
  box-shadow: none;
  cursor: not-allowed;
}

.btn.confirm:not([disabled]):active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 4rpx rgba(52,152,219,0.3);
}