/* pages/feedback/feedback.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f6f8;
  padding: 24rpx;
  box-sizing: border-box;
}

.tips-card {
  background: linear-gradient(135deg, #e8f4ff, #f0f8ff);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #3498db;
}

.tips-text {
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.5;
}

.record-entry {
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-entry-text {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 600;
}

.record-entry .arrow {
  color: #999;
  font-size: 32rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 0 28rpx 28rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-value .arrow {
  color: #999;
  font-size: 32rpx;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.placeholder {
  color: #999;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.input {
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.image-upload-wrap {
  margin-top: 8rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.image-item .thumb {
  width: 100%;
  height: 100%;
}

.image-item .thumb-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 36rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 0 0 0 12rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.image-add .add-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  margin-bottom: 8rpx;
}

.image-add .add-text {
  font-size: 24rpx;
  color: #999;
}

.btn-wrap {
  padding: 0 10rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #2c3e50, #4a6491);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-submit:active {
  opacity: 0.9;
}
