<!--pages/renew/renew.wxml-->
<view class="container">
  <view class="card" wx:if="{{!hasActive}}">
    <view class="card-title">座位续约</view>
    <view class="card-desc">您当前没有进行中的预约，无法续约。请先预约座位。</view>
    <view class="btn-primary" style="margin-top:24rpx" bindtap="goBack">返回首页</view>
  </view>

  <block wx:if="{{hasActive}}">
    <view class="card">
      <view class="card-title">当前预约</view>
      <view class="info-row">座位：{{reservation.seatId}}</view>
      <view class="info-row">状态：{{reservation.statusText}}</view>
      <view class="info-row">当前结束时间：{{reservation.endAtText}}</view>
    </view>

    <view class="card">
      <view class="card-title">续约时长</view>
      <picker mode="selector" range="{{renewOptions}}" range-key="label" value="{{renewIndex}}" bindchange="onRenewDurationChange">
        <view class="picker">{{renewOptions[renewIndex].label}}</view>
      </picker>
      <view class="card-desc" style="margin-top:16rpx">在当前结束时间基础上延长所选时长。</view>
      <view class="btn-primary" style="margin-top:24rpx" bindtap="submitRenew">确认续约</view>
    </view>

    <view class="btn-cancel" bindtap="cancelReservation">取消当前预约</view>
  </block>
</view>
