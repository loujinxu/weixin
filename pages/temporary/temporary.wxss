/* pages/temporary/temporary.wxss */
.container {
  min-height: 100vh;
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Microsoft YaHei', sans-serif;
  padding: 0;
  margin: 0;
}

.header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.seat-info {
  padding: 30rpx 40rpx;
  background: linear-gradient(135deg, #fef9e7, #fdebd0);
  border-bottom: 2rpx solid #e67e22;
  animation: fadeInUp 0.5s ease-out 0.1s both;
  box-shadow: 0 4rpx 12rpx rgba(230, 126, 34, 0.1);
}

.info-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background-color: white;
  padding: 25rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e67e22;
  box-shadow: 0 6rpx 20rpx rgba(230, 126, 34, 0.2);
  text-align: center;
}

.info-label {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.seat-display {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.seat-number-big {
  font-size: 50rpx;
  color: #e67e22;
  font-weight: bold;
  text-shadow: 0 2rpx 6rpx rgba(230, 126, 34, 0.3);
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #e67e22, #d35400);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  padding: 0 10rpx;
}

.temp-status {
  font-size: 32rpx;
  color: #e67e22;
  background-color: #fef5e7;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e67e22;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(230, 126, 34, 0.2);
}

.countdown-section {
  padding: 40rpx 30rpx;
  background-color: #fef9e7;
  border-bottom: 1rpx solid #fdebd0;
  animation: fadeInUp 0.5s ease-out 0.2s both;
}

.countdown-title {
  font-size: 32rpx;
  color: #e67e22;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.countdown-display {
  background: linear-gradient(135deg, #e67e22, #d35400);
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(230, 126, 34, 0.3);
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

.countdown-display::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transform: translateX(-100%);
  animation: shine 3s infinite;
}

.countdown-text {
  font-size: 72rpx;
  color: white;
  font-weight: bold;
  font-family: 'Courier New', monospace;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  position: relative;
  z-index: 1;
}

.tip-text {
  font-size: 28rpx;
  color: #e67e22;
  text-align: center;
  font-weight: 500;
  background-color: white;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid #fdebd0;
  line-height: 1.6;
}

.action-section {
  padding: 40rpx 30rpx;
  animation: fadeInUp 0.5s ease-out 0.3s both;
}

.action-btn {
  width: 100%;
  height: 120rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
  border: none;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  background: linear-gradient(135deg, #2980b9, #1c6ea4);
  transform: translateY(-2rpx) scale(0.98);
  box-shadow: 0 4rpx 8rpx rgba(52, 152, 219, 0.3);
}