<view class="container">
  <view class="admin-entry" wx:if="{{isAdmin}}" bindtap="goAdmin">
    <text class="admin-entry-text">进入反馈管理（管理员）</text>
    <text class="arrow">›</text>
  </view>

  <view class="list" wx:if="{{list.length}}">
    <view class="card" wx:for="{{list}}" wx:key="_id">
      <view class="row">
        <text class="type">{{item.type}}</text>
        <view class="status {{item.status === 'done' ? 'done' : 'pending'}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
      <text class="content">{{item.content}}</text>
      <text class="meta" wx:if="{{item.location}}">位置：{{item.location}}</text>
      <text class="meta">{{item.timeText}}</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-title">暂无反馈记录</text>
    <text class="empty-sub">去提交一个问题反馈吧</text>
    <button class="btn" bindtap="goFeedback">去反馈</button>
  </view>
</view>

