/* pages/reservation/reservation.wxss */
.reservation-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  width: 100%;
  box-sizing: border-box;
}

.seat-info-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-left: 8rpx solid #4a90e2;
  position: relative;
}

.card-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 20rpx;
  text-align: center;
}

.seat-number {
  font-size: 48rpx;
  color: #4a90e2;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-align: center;
}

.reservation-hours {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 10rpx;
}

.reservation-count {
  font-size: 24rpx;
  color: #27ae60;
  background-color: #e8f8f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #27ae60;
  text-align: center;
}

.renew-indicator {
  font-size: 24rpx;
  color: #e67e22;
  background-color: #fef5e7;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e67e22;
  text-align: center;
}

.countdown-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4a90e2, #2e6fba);
  border-left: 8rpx solid #1e5fa0;
}

.countdown-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 20rpx;
  text-align: center;
}

.countdown-text {
  font-size: 72rpx;
  color: white;
  font-weight: bold;
  font-family: 'Courier New', 'Consolas', monospace;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.temp-info-card {
  border-left: 8rpx solid #f5a623;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.temp-leave-count {
  font-size: 36rpx;
  color: #f5a623;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-align: center;
}

.temp-leave-description {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}

.action-buttons {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: none;
  margin: 0;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.temp-leave-btn {
  background: linear-gradient(135deg, #f5a623, #e68a00);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.3);
}

.temp-leave-btn[disabled] {
  background: #cccccc;
  color: #999999;
  box-shadow: none;
}

.end-reservation-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(231,76,60,0.3);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-container {
  width: 80vw;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

.modal-header {
  padding: 40rpx 30rpx 20rpx;
  background-color: #4a90e2;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
}

.modal-content {
  padding: 40rpx 30rpx;
  text-align: center;
}

.modal-message {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.modal-subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.usage-info {
  font-size: 26rpx;
  color: #27ae60;
  background-color: #e8f8f0;
  padding: 15rpx 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #27ae60;
  margin-top: 20rpx;
}

.modal-actions {
  padding: 0 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-button {
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.modal-button:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.renew-button {
  background: linear-gradient(135deg, #27ae60, #219653);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(39,174,96,0.3);
}

.rebook-button {
  background: linear-gradient(135deg, #f5a623, #e68a00);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.3);
}

.confirm-button {
  background-color: #f8f9fa;
  color: #666666;
  border: 2rpx solid #e0e0e0;
}