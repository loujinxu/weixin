/* pages/templeave/templeave.wxss */
.countdown-card {
  background: linear-gradient(135deg, #f57c00 0%, #ffb74d 100%);
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
  margin-bottom: 48rpx;
}
.countdown-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 16rpx;
}
.countdown-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}
.btn-primary {
  margin-top: 24rpx;
}
